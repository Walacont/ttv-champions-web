rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is coach or admin
    function isCoachOrAdmin() {
      return request.auth != null &&
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['coach', 'admin'];
    }

    // Helper function to validate image files (type and size)
    function isValidImage() {
      return request.resource.contentType.matches('image/(jpeg|jpg|png|gif|webp)')
             && request.resource.size < 5 * 1024 * 1024; // Max 5MB
    }

    // Helper function for smaller images (profile pics, logos)
    function isValidSmallImage() {
      return request.resource.contentType.matches('image/(jpeg|jpg|png|gif|webp)')
             && request.resource.size < 2 * 1024 * 1024; // Max 2MB
    }

    // Exercise images - coaches and admins can upload, everyone can read
    match /exercises/{imageId} {
      allow read: if request.auth != null;
      allow write: if isCoachOrAdmin() && isValidImage();
    }

    // Player profile pictures - users can upload their own, everyone can read
    match /profiles/{userId}/{imageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && isValidSmallImage();
    }

    // Legacy path for profile pictures (backwards compatibility)
    match /profile-pictures/{userId}/{imageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && isValidSmallImage();
    }

    // Club logos - coaches can upload for their club, everyone can read
    match /clubs/{clubId}/{imageId} {
      allow read: if request.auth != null;
      allow write: if isCoachOrAdmin() && isValidSmallImage();
    }

    // Default: deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
